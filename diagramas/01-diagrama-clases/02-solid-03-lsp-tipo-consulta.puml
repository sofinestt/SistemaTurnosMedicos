@startuml diagrama-lsp-tipo-consulta

' ============================================
' DIAGRAMA 2: Jerarquía TipoConsulta (cumple LSP)
' ============================================

package "Jerarquía TipoConsulta - Cumple LSP" {
    abstract class TipoConsulta {
        +getDuracionPrevista(): int
        +getDescripcion(): String
    }

    class Control {
        -duracionMinutos: int = 15
        +getDuracionPrevista(): int
        +getDescripcion(): String
    }

    class PrimeraVez {
        -duracionMinutos: int = 30
        +permiteExtension: boolean = true
        +getDuracionPrevista(): int
        +getDescripcion(): String
    }

    class Procedimiento {
        -duracionMinutos: int = 45
        +permiteExtension: boolean = true
        +getDuracionPrevista(): int
        +getDescripcion(): String
    }
}

TipoConsulta <|-- Control
TipoConsulta <|-- PrimeraVez
TipoConsulta <|-- Procedimiento

note right of TipoConsulta
  <b>Contrato abstracto:</b>
  +getDuracionPrevista(): int
  +getDescripcion(): String
  <b>Todas las subclases deben
  implementar estos métodos</b>
end note

note right of Control
  <b>✅ Cumple LSP</b>
  - Implementa completamente
    el contrato
  - Retorna 15 minutos
  - No debilita postcondiciones
  - No strengthen precondiciones
end note

note right of PrimeraVez
  <b>✅ Cumple LSP</b>
  - Implementa completamente
    el contrato
  - Retorna 30 minutos
  - Agrega propiedad extra
    (permiteExtension)
  - Comportamiento consistente
end note

note right of Procedimiento
  <b>✅ Cumple LSP</b>
  - Implementa completamente
    el contrato
  - Retorna 45 minutos
  - Ejemplo de extensión
    sin modificar código
    existente (OCP + LSP)
end note

' ============================================
' Relación con Turno
' ============================================

class Turno {
    -fecha: Date
    -hora: Time
    -estado: String
    -tipoConsulta: TipoConsulta
    +getDuracion(): int
    +setTipoConsulta(TipoConsulta)
}

Turno o-- TipoConsulta : "usa"

note bottom of Turno
  <b>Cliente de TipoConsulta</b>
  Turno usa la abstracción,
  no conoce las subclases
  específicas.
  <b>Esto permite:</b>
  - Agregar nuevos tipos
    sin modificar Turno
  - Sustituir cualquier
    subclase por otra
    (cumple LSP)
end note

@enduml